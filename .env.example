# ─── Telegram ─────────────────────────────────────────────────────────────────
# Token do bot criado pelo @BotFather
TELEGRAM_TOKEN=

# ID do grupo/chat onde o bot envia os leads
# Dica: adicione o bot ao grupo, envie uma mensagem e acesse
# https://api.telegram.org/bot<TOKEN>/getUpdates para pegar o chat_id
TELEGRAM_CHAT_ID=

# ─── Brevo (e-mail transacional) ──────────────────────────────────────────────
# API Key → https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# E-mail que VAI RECEBER os leads (qualquer endereço)
BREVO_TO_EMAIL=

# E-mail REMETENTE (deve estar verificado no Brevo como domínio ou sender)
BREVO_FROM_EMAIL=

# Nome exibido como remetente
BREVO_FROM_NAME=Efreire Assessoria & Estratégia Financeira

# ─── WhatsApp (client-side, exibido no site) ──────────────────────────────────
VITE_WHATSAPP=5511991978970
